# pg-mcp-server — docker-compose environment
# Copy to .env and adjust values before running `docker compose up -d`.

# ── MCP server ────────────────────────────────────────────────────────────────

# Host port the server listens on (container always uses 3000)
MCP_PORT=3000

# Name shown in MCP clients (e.g. Claude browser tab) and the Admin UI.
# Default: pg-mcp-server
# MCP_SERVER_NAME=my-production-db

# Admin bearer token for /mcp and /admin/tokens.
# Generate with: openssl rand -hex 32
# Leave empty to disable authentication (development only).
AUTH_TOKEN=

# ── PostgreSQL (default connection) ──────────────────────────────────────────

PG_HOST=postgres-test
PG_PORT=5432
PG_DATABASE=testdb
PG_USER=postgres
PG_PASSWORD=postgres

# PostgreSQL TLS: false | true | verify
PG_SSL=false

# CA certificate for PG_SSL=verify (path inside container)
# PG_SSL_CA_FILE=/certs/pg-ca.crt

# ── TLS (HTTPS) ───────────────────────────────────────────────────────────────

# Set to true to enable HTTPS. Requires a cert volume mounted at /certs.
TLS_ENABLED=false

# Additional SANs for the auto-generated self-signed certificate.
# Example: DNS:myhost.local,IP:192.168.1.10
# TLS_SAN=
